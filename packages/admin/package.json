{
  "name": "@yok-ui/admin",
  "version": "0.1.0",
  "description": "Admin workflow and data-operation components for Yok UI.",
  "type": "module",
  "license": "MIT",
  "keywords": [
    "vue",
    "vue3",
    "admin",
    "data-table",
    "design-system",
    "yok-ui"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/yokry-he/yok-ui.git",
    "directory": "packages/admin"
  },
  "homepage": "https://github.com/yokry-he/yok-ui/tree/main/packages/admin#readme",
  "bugs": {
    "url": "https://github.com/yokry-he/yok-ui/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "sideEffects": ["**/*.css"],
  "files": [
    "dist",
    "README.md"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./style.css": "./dist/index.css"
  },
  "scripts": {
    "build": "vite build && vue-tsc -p tsconfig.build.json --declaration --emitDeclarationOnly --outDir dist --skipLibCheck",
    "typecheck": "vue-tsc --noEmit --skipLibCheck"
  },
  "peerDependencies": {
    "vue": "^3.5.0"
  },
  "dependencies": {
    "@yok-ui/core": "workspace:*"
  }
}
