{
  "name": "@yok-ui/icons",
  "version": "0.1.0",
  "description": "Small SVG icon primitives and Vue renderers for Yok UI.",
  "type": "module",
  "license": "MIT",
  "keywords": [
    "vue",
    "vue3",
    "icons",
    "svg",
    "yok-ui"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/yokry-he/yok-ui.git",
    "directory": "packages/icons"
  },
  "homepage": "https://github.com/yokry-he/yok-ui/tree/main/packages/icons#readme",
  "bugs": {
    "url": "https://github.com/yokry-he/yok-ui/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "sideEffects": false,
  "files": [
    "dist",
    "README.md"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "vite build && vue-tsc -p tsconfig.build.json --declaration --emitDeclarationOnly --outDir dist --skipLibCheck",
    "typecheck": "vue-tsc --noEmit --skipLibCheck"
  },
  "peerDependencies": {
    "vue": "^3.5.0"
  }
}
