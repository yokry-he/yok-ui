{
  "name": "@yok-ui/themes",
  "version": "0.1.0",
  "description": "Theme tokens, theme CSS files and contrast helpers for Yok UI.",
  "type": "module",
  "license": "MIT",
  "keywords": [
    "vue",
    "theme",
    "tokens",
    "design-system",
    "yok-ui"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/yokry-he/yok-ui.git",
    "directory": "packages/themes"
  },
  "homepage": "https://github.com/yokry-he/yok-ui/tree/main/packages/themes#readme",
  "bugs": {
    "url": "https://github.com/yokry-he/yok-ui/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "sideEffects": ["**/*.css"],
  "files": [
    "dist",
    "src/themes/*.css",
    "README.md"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./yok-light.css": "./src/themes/yok-light.css",
    "./yok-clean.css": "./src/themes/yok-clean.css",
    "./yok-candy.css": "./src/themes/yok-candy.css",
    "./yok-mint.css": "./src/themes/yok-mint.css",
    "./yok-ocean.css": "./src/themes/yok-ocean.css",
    "./yok-sakura.css": "./src/themes/yok-sakura.css",
    "./yok-lavender.css": "./src/themes/yok-lavender.css",
    "./yok-sunrise.css": "./src/themes/yok-sunrise.css",
    "./yok-forest.css": "./src/themes/yok-forest.css",
    "./yok-ink.css": "./src/themes/yok-ink.css",
    "./yok-peach.css": "./src/themes/yok-peach.css",
    "./yok-slate.css": "./src/themes/yok-slate.css"
  },
  "scripts": {
    "build": "vite build && vue-tsc -p tsconfig.build.json --declaration --emitDeclarationOnly --outDir dist --skipLibCheck",
    "typecheck": "vue-tsc --noEmit --skipLibCheck"
  },
  "peerDependencies": {
    "vue": "^3.5.0"
  }
}
