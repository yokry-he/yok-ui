{
  "compilerOptions": {
    "target": "ES2022",
    "useDefineForClassFields": true,
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "baseUrl": ".",
    "paths": {
      "@yok-ui/themes": ["packages/themes/src"],
      "@yok-ui/core": ["packages/core/src"],
      "@yok-ui/product": ["packages/product/src"],
      "@yok-ui/hooks": ["packages/hooks/src"],
      "@yok-ui/icons": ["packages/icons/src"]
    },
    "strict": true,
    "jsx": "preserve",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "esModuleInterop": true,
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "skipLibCheck": true,
    "types": ["vitest/globals"]
  }
}
